{
  "name": "@bookklik/senangstart-css",
  "version": "0.3.0",
  "description": "Fluent Style Utilities for Humans and AI",
  "type": "module",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    },
    "./cli": "./src/cli/index.js"
  },
  "files": [
    "dist",
    "src",
    "types",
    "templates",
    "LICENSE.md",
    "README.md"
  ],
  "bin": {
    "senangstart": "./src/cli/index.js",
    "sen": "./src/cli/index.js"
  },
  "scripts": {
    "dev": "node src/cli/index.js dev",
    "build": "npm run build:dist && npm run docs:generate && vitepress build docs && npm run docs:llms",
    "build:dist": "node scripts/build-dist.js",
    "prepublishOnly": "npm test && npm run build:dist",
    "postinstall": "node scripts/generate-types.js",
    "docs:dev": "vitepress dev docs",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:sync-check": "node scripts/generate-docs.js --compare",
    "docs:syntax": "node scripts/extract-syntax.js",
    "docs:llms": "node scripts/generate-llms-txt.js",
    "test": "node --test tests/",
    "test:unit": "node --test tests/unit/",
    "test:integration": "node --test tests/integration/",
    "test:sync": "node --test tests/sync/",
    "test:watch": "node --test --watch tests/",
    "test:coverage": "npx c8 --reporter=text --reporter=html node --test tests/",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "lint": "eslint src/",
    "lint:css": "stylelint \"public/**/*.css\" \"dist/**/*.css\"",
    "lint:css:fix": "stylelint \"public/**/*.css\" \"dist/**/*.css\" --fix"
  },
  "keywords": [
    "css",
    "framework",
    "utility-css",
    "natural-language",
    "intent-first"
  ],
  "homepage": "https://bookklik-technologies.github.io/senangstart-css",
  "repository": {
    "type": "git",
    "url": "https://github.com/bookklik-technologies/senangstart-css.git"
  },
  "bugs": {
    "url": "https://github.com/bookklik-technologies/senangstart-css/issues"
  },
  "author": "a-hakim",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.5.3",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.0.0",
    "http-server": "^14.1.1",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "vitepress": "^1.6.4"
}
}
